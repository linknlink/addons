{
    "name": "HACS Installer",
    "version": "1.0.0",
    "slug": "hacs_installer",
    "description": "安装 HACS 文件，并引导完成 Home Assistant 集成配置",
    "arch": [
        "aarch64",
        "amd64",
        "armv7"
    ],
    "startup": "services",
    "boot": "manual",
    "ingress": true,
    "ingress_port": 8202,
    "options": {
        "ha_config_path": "/usr/share/hassio/homeassistant"
    },
    "schema": {
        "ha_config_path": "str"
    }
}
